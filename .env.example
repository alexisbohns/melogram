NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by /api/storage to write audio/cover objects with the
# service role after verifying artist membership. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=
# Canonical public origin (e.g. https://melogram.app). Sets metadataBase so the
# generated Open Graph / Twitter share images resolve to absolute URLs. On
# Vercel it falls back to the deploy URL; locally it defaults to localhost:3000.
NEXT_PUBLIC_SITE_URL=
